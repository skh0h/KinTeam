{
  "name": "AdminAlert",
  "type": "object",
  "properties": {
    "message": {
      "type": "string",
      "description": "The alert message"
    },
    "from_member": {
      "type": "string",
      "description": "Display name of the member who sent it"
    },
    "task_title": {
      "type": "string",
      "description": "Title of the chore"
    },
    "task_id": {
      "type": "string",
      "description": "ID of the FamilyTask this alert is about"
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "approved",
        "rejected"
      ],
      "default": "pending",
      "description": "Admin review status"
    },
    "user_notified": {
      "type": "boolean",
      "default": false,
      "description": "Whether user has seen the rejection notification"
    }
  },
  "required": [
    "message",
    "from_member",
    "task_id"
  ]
}