{
  "name": "HouseholdSettings",
  "type": "object",
  "properties": {
    "mode": {
      "type": "string",
      "enum": [
        "normal",
        "workhorse",
        "vacation"
      ],
      "default": "normal",
      "description": "Current household mode"
    },
    "auto_set": {
      "type": "boolean",
      "default": false,
      "description": "Whether the current mode was set by the scheduler"
    }
  }
}