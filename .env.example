# Copy this file to .env.local and fill in the values for your environment.
# .env.local is gitignored and must never be committed.

# ─── Backend selector ────────────────────────────────────────────────────────
# Choose which backend the app connects to.
# Accepted values: "base44" | "supabase"
# Default is "base44" (legacy / always-on fallback).
# Flip to "supabase" to use the Supabase backend — no component edits needed.
VITE_BACKEND=base44

# ─── Supabase backend ────────────────────────────────────────────────────────
# Only required when VITE_BACKEND=supabase.
# Project URL (public, safe to commit as a reference value).
VITE_SUPABASE_URL=https://djnhsgfldbizgqfdpayn.supabase.co
# Anon / publishable key — browser-safe, NOT the service_role key.
# Find it in: Supabase dashboard → Project Settings → API → Project API keys → anon public
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# ─── Base44 backend (legacy fallback / default) ───────────────────────────────
# Required when VITE_BACKEND=base44 (or left unset).
VITE_BASE44_APP_ID=your-base44-app-id-here
VITE_BASE44_FUNCTIONS_VERSION=your-base44-functions-version-here
VITE_BASE44_APP_BASE_URL=your-base44-app-base-url-here
